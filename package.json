{
	"name": "blender-render-suite",
	"version": "1.0.0",
	"description": "A modern Blender rendering interface",
	"license": "MIT",
	"author": "Nebula Studios",
	"main": "main.js",
	"scripts": {
		"dev": "node scripts/dev.js",
		"next-dev": "next dev",
		"electron-dev": "wait-on tcp:3000 && electron .",
		"build": "next build",
		"build:electron": "electron-builder",
		"build:all": "npm run build && npm run build:electron",
		"start": "electron ."
	},
	"build": {
		"appId": "com.nebulastudios.blenderrendersuite",
		"productName": "Blender Render Suite",
		"directories": {
			"output": "release"
		},
		"files": [
			"main.js",
			"preload.js",
			"package.json"
		],
		"extraResources": [
			{
				"from": "dist",
				"to": "app.asar.unpacked/dist",
				"filter": ["**/*"]
			}
		],
		"win": {
			"target": "nsis",
			"icon": "src/app/icon.ico"
		},
		"mac": {
			"target": "dmg",
			"icon": "src/app/icon.icns"
		},
		"linux": {
			"target": "AppImage",
			"icon": "src/app/icon.png"
		}
	},
	"dependencies": {
		"@heroui/react": "^2.7.5",
		"@radix-ui/react-accordion": "^1.2.3",
		"@radix-ui/react-checkbox": "^1.0.4",
		"@radix-ui/react-dialog": "^1.0.5",
		"@radix-ui/react-label": "^2.0.2",
		"@radix-ui/react-progress": "^1.0.3",
		"@radix-ui/react-scroll-area": "^1.0.5",
		"@radix-ui/react-select": "^2.0.0",
		"@radix-ui/react-separator": "^1.0.3",
		"@radix-ui/react-switch": "^1.1.3",
		"@radix-ui/react-tabs": "^1.0.4",
		"@radix-ui/react-tooltip": "^1.0.7",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"electron-squirrel-startup": "^1.0.1",
		"electron-store": "^8.2.0",
		"framer-motion": "^12.6.0",
		"fs": "^0.0.1-security",
		"lucide-react": "^0.321.0",
		"next": "^14.1.0",
		"next-themes": "^0.4.6",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-hot-toast": "^2.4.1",
		"react-resizable-panels": "^2.1.7",
		"tailwind-merge": "^2.6.0",
		"tailwindcss-animate": "^1.0.7",
		"tw-animate-css": "^1.2.4",
		"uuid": "^9.0.1"
	},
	"devDependencies": {
		"@types/node": "^20.11.0",
		"@types/react": "^18.2.0",
		"@types/react-dom": "^18.2.0",
		"@types/uuid": "^9.0.8",
		"autoprefixer": "^10.4.17",
		"concurrently": "^9.1.2",
		"electron": "^35.0.3",
		"electron-builder": "^24.9.1",
		"postcss": "^8.4.35",
		"tailwindcss": "^3.4.1",
		"typescript": "^5.3.3",
		"wait-on": "^8.0.3"
	}
}
